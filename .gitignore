# Secrets & credentials — NEVER commit
*.env
*.env.*
!*.env.example
!*.env.template
*-env.sh
!*-env.sh.template
*.pem
*.key
*.p8
*.crt

# Identity / device auth
identity/
device*.json
device-auth*.json

# Provider configs that hold tokens
.cloudflared/
rclone.conf
**/credentials/

# Runtime state
cron/delivery-queue/
logs/
*.log
*.pid
*.lock

# OS / editor
.DS_Store
.idea/
.vscode/
*.swp
*~

# Node / misc
node_modules/
dist/
build/

# Records monitor runtime state — personal data, never commit
records-monitor/seen-docs.json
records-monitor/cookies.txt
records-monitor/nr-cookies.txt
records-monitor/*.json.bak
records-monitor/prr-list.json

# Beads sync runtime
beads-sync/*.jsonl
beads-sync/*.db
