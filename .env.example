# OpenClaw VPS Setup — Environment Variables
# Copy this file to .env and fill in your values.
# Never commit .env to git.

# ── Telegram ──────────────────────────────────────────────────────────────────
# Create a bot via @BotFather. Get the chat ID by messaging your bot and
# calling https://api.telegram.org/bot<TOKEN>/getUpdates
TELEGRAM_BOT_TOKEN=YOUR_TELEGRAM_BOT_TOKEN
TELEGRAM_CHAT_ID=YOUR_TELEGRAM_CHAT_ID

# ── Composio ──────────────────────────────────────────────────────────────────
# https://app.composio.dev — create a free account, connect Google Drive,
# then copy the API key from Settings > API Keys.
COMPOSIO_API_KEY=YOUR_COMPOSIO_API_KEY

# ── Google Drive folder IDs ───────────────────────────────────────────────────
# Right-click a folder in Drive → Get link → copy the ID from the URL
# (the long string after /folders/)
DRIVE_ROOT_FOLDER_ID=YOUR_DRIVE_ROOT_FOLDER_ID
DRIVE_CONTROLLER_FOLDER_ID=YOUR_DRIVE_CONTROLLER_FOLDER_ID
DRIVE_SFFD_FOLDER_ID=YOUR_DRIVE_SFFD_FOLDER_ID
DRIVE_SFPUC_FOLDER_ID=YOUR_DRIVE_SFPUC_FOLDER_ID

# ── VPS connection ────────────────────────────────────────────────────────────
# Tailscale IP (preferred) or public IP if you've secured it otherwise
VPS_SSH_HOST=YOUR_VPS_IP
VPS_SSH_PORT=2222

# ── NextRequest ───────────────────────────────────────────────────────────────
# Base URL for your agency's NextRequest portal
NR_BASE_URL=https://youragency.nextrequest.com
# Session cookie — log in via browser, copy from DevTools > Application > Cookies
NR_SESSION_COOKIE=YOUR_NR_SESSION_COOKIE

# ── Linear (optional — only needed if you use Linear task routing) ────────────
LINEAR_API_KEY=YOUR_LINEAR_API_KEY
LINEAR_TEAM_ID=YOUR_LINEAR_TEAM_ID
LINEAR_ASSIGNEE_ID=YOUR_LINEAR_ASSIGNEE_ID
